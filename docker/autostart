#!/bin/bash
# 由 KasmVNC base 的 openbox 会话在桌面就绪后执行（以 app 用户身份）。
# 多应用：实例承载的应用由面板注入 WOC_APP_TYPE，再由 02-woc-app 钩子落到 /config/.woc-app。
# 本脚本据此等待对应应用就绪并常驻拉起；读不到类型则使用默认微信。

set -u

if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] && [ -z "${WOC_DBUS_SESSION_STARTED:-}" ]; then
    export WOC_DBUS_SESSION_STARTED=1
    exec dbus-run-session -- "$0" "$@"
fi

# 强制软件渲染
export LIBGL_ALWAYS_SOFTWARE=1
# 微信内置 WeChatAppEx/Qt WebEngine 和系统 Chromium 在容器里都不能依赖浏览器 sandbox。
# Qt 官方支持用这些环境变量透传 Chromium 参数；外链默认浏览器走下方 xdg-mime 配置。
export QTWEBENGINE_DISABLE_SANDBOX=1
case " ${QTWEBENGINE_CHROMIUM_FLAGS:-} " in
    *" --no-sandbox "*) ;;
    *) export QTWEBENGINE_CHROMIUM_FLAGS="${QTWEBENGINE_CHROMIUM_FLAGS:+$QTWEBENGINE_CHROMIUM_FLAGS }--no-sandbox" ;;
esac
export BROWSER="${BROWSER:-/usr/local/bin/woc-browser}"

if command -v xdg-mime >/dev/null 2>&1 && [ -f /usr/share/applications/woc-browser.desktop ]; then
    xdg-mime default woc-browser.desktop x-scheme-handler/http 2>/dev/null || true
    xdg-mime default woc-browser.desktop x-scheme-handler/https 2>/dev/null || true
    xdg-mime default woc-browser.desktop text/html 2>/dev/null || true
fi

APP_TYPE=wechat
# shellcheck source=/dev/null
[ -f /config/.woc-app ] && . /config/.woc-app 2>/dev/null || true
APP_TYPE="${WOC_APP_TYPE:-wechat}"
# shellcheck source=/dev/null
. /woc/app-defs.sh
woc_app_def "$APP_TYPE" || exit 1

# 桌面通知桥必须在应用启动前接管 org.freedesktop.Notifications，
# 否则部分客户端启动时探测不到通知服务后不会再重试。
if command -v woc-notifyd >/dev/null 2>&1; then
    woc-notifyd >>/tmp/woc-notifyd.log 2>&1 &
fi

# 防“最小化后丢失”：本桌面（openbox）无任务栏，窗口被最小化就无处恢复 → 黑屏。
# 看守进程：每 2s 把“被最小化（不可见）”的顶层窗口重新激活，相当于禁用最小化。
(
    export DISPLAY="${DISPLAY:-:1}"
    while sleep 2; do
        all=$(xdotool search --name '.+' 2>/dev/null) || continue
        vis=$(xdotool search --onlyvisible --name '.+' 2>/dev/null)
        for w in ${all}; do
            printf '%s\n' "${vis}" | grep -qx "${w}" || xdotool windowactivate "${w}" 2>/dev/null || true
        done
    done
) &

# 1) 等待应用安装就绪（需要安装的应用首次需在面板点「下载并安装」；Chromium 随镜像就绪）
notified=0
while [ -n "${APP_BIN:-}" ] && [ ! -x "${APP_BIN}" ]; do
    if [ "${notified}" -eq 0 ]; then
        echo "[autostart] ${APP_NAME} 尚未安装，等待面板触发下载…（首次使用请在面板点「下载并安装」）"
        notified=1
    fi
    sleep 2
done

# 2) 常驻拉起应用
while true; do
    if [ -n "${APP_BIN:-}" ] && [ ! -x "${APP_BIN}" ]; then
        # 更新过程中本体被临时挪走，等就位再继续
        sleep 2
        continue
    fi
    echo "[autostart] 启动 ${APP_NAME}: ${APP_LAUNCH}"
    ${APP_LAUNCH}
    echo "[autostart] ${APP_NAME} 已退出，2 秒后重启"
    sleep 2
done
