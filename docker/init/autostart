#!/bin/bash
# 由 KasmVNC base 的 openbox 会话在桌面就绪后执行（以 app 用户身份）。
# 多应用：实例承载的应用由面板注入 WOC_APP_TYPE，再由 02-woc-app 钩子落到 /config/.woc-app。
# 本脚本据此等待对应应用就绪并常驻拉起；读不到类型则使用默认微信。

set -u

if [ -z "${DBUS_SESSION_BUS_ADDRESS:-}" ] && [ -z "${WOC_DBUS_SESSION_STARTED:-}" ]; then
    export WOC_DBUS_SESSION_STARTED=1
    exec dbus-run-session -- "$0" "$@"
fi

export BROWSER="${BROWSER:-/usr/local/bin/woc-open-url}"

if command -v xdg-mime >/dev/null 2>&1 && [ -f /usr/share/applications/woc-browser.desktop ]; then
    xdg-mime default woc-browser.desktop x-scheme-handler/http 2>/dev/null || true
    xdg-mime default woc-browser.desktop x-scheme-handler/https 2>/dev/null || true
    xdg-mime default woc-browser.desktop text/html 2>/dev/null || true
fi

APP_TYPE=wechat
# shellcheck source=/dev/null
[ -f /config/.woc-app ] && . /config/.woc-app 2>/dev/null || true
APP_TYPE="${WOC_APP_TYPE:-wechat}"
# shellcheck source=/dev/null
. /woc/app-defs.sh
# shellcheck source=/dev/null
. /woc/window-guard.sh
woc_app_def "$APP_TYPE" || exit 1
woc_apply_app_runtime_env "${APP_RUNTIME_PROFILE:-software}" || exit 1
woc_prepare_app_runtime "$APP_TYPE"

AUTOSTART_KEY="$(printf '%s-%s' "${APP_TYPE}" "${DISPLAY:-:1}" | tr -c 'A-Za-z0-9_.-' '_')"
AUTOSTART_STATE_DIR=/tmp/woc-autostart
AUTOSTART_PID_FILE="${AUTOSTART_STATE_DIR}/${AUTOSTART_KEY}.pid"
AUTOSTART_WATCHER_PID_FILE="${AUTOSTART_STATE_DIR}/${AUTOSTART_KEY}.watcher.pid"
NOTIFY_PID=

process_alive() {
    local pid="$1"
    case "${pid:-}" in
        ''|*[!0-9]* ) return 1 ;;
    esac
    kill -0 "${pid}" 2>/dev/null
}

stop_pid_file_process() {
    local file="$1" pid current
    [ -f "${file}" ] || return 0
    pid="$(cat "${file}" 2>/dev/null || true)"
    current="$$"
    if [ "${pid:-}" = "${current}" ]; then
        return 0
    fi
    if process_alive "${pid:-}"; then
        kill -TERM "${pid}" 2>/dev/null || true
        for _ in 1 2 3 4 5; do
            process_alive "${pid}" || break
            sleep 0.2
        done
        process_alive "${pid}" && kill -KILL "${pid}" 2>/dev/null || true
    fi
    rm -f "${file}"
}

cleanup_autostart() {
    local pid current
    current="$$"
    if [ -f "${AUTOSTART_WATCHER_PID_FILE}" ]; then
        pid="$(cat "${AUTOSTART_WATCHER_PID_FILE}" 2>/dev/null || true)"
        process_alive "${pid:-}" && kill -TERM "${pid}" 2>/dev/null || true
        rm -f "${AUTOSTART_WATCHER_PID_FILE}"
    fi
    process_alive "${NOTIFY_PID:-}" && kill -TERM "${NOTIFY_PID}" 2>/dev/null || true
    if [ -f "${AUTOSTART_PID_FILE}" ] && [ "$(cat "${AUTOSTART_PID_FILE}" 2>/dev/null || true)" = "${current}" ]; then
        rm -f "${AUTOSTART_PID_FILE}"
    fi
}

mkdir -p "${AUTOSTART_STATE_DIR}"
stop_pid_file_process "${AUTOSTART_WATCHER_PID_FILE}"
stop_pid_file_process "${AUTOSTART_PID_FILE}"
printf '%s\n' "$$" > "${AUTOSTART_PID_FILE}"
trap cleanup_autostart EXIT
trap 'cleanup_autostart; exit 0' INT TERM

# 桌面通知桥必须在应用启动前接管 org.freedesktop.Notifications，
# 否则部分客户端启动时探测不到通知服务后不会再重试。
if command -v woc-notifyd >/dev/null 2>&1; then
    pkill -f 'python3 /usr/local/bin/woc-notifyd|/usr/local/bin/woc-notifyd|woc-notifyd' 2>/dev/null || true
    woc-notifyd &
    NOTIFY_PID="$!"
fi

# 窗口看守：每 2s 恢复最小化的应用窗口，并把当前应用主窗口重新最大化。
# KasmVNC 的 resize=remote 会随浏览器视口改变远端桌面；微信/QQ 有时不会跟随新桌面尺寸，
# 尤其是多个保活 VNC iframe 来回切换后，所以这里在容器内按 openbox 状态兜底。
woc_start_window_guard "${AUTOSTART_PID_FILE}" "${AUTOSTART_WATCHER_PID_FILE}"

# 1) 等待应用安装就绪（需要安装的应用首次需在面板点「下载并安装」；Chromium 随镜像就绪）
notified=0
while [ -n "${APP_BIN:-}" ] && [ ! -x "${APP_BIN}" ]; do
    if [ "${notified}" -eq 0 ]; then
        echo "[autostart] ${APP_NAME} 尚未安装，等待面板触发下载…（首次使用请在面板点「下载并安装」）"
        notified=1
    fi
    sleep 2
done

# 2) 常驻拉起应用
while true; do
    if [ -n "${APP_BIN:-}" ] && [ ! -x "${APP_BIN}" ]; then
        # 更新过程中本体被临时挪走，等就位再继续
        sleep 2
        continue
    fi
    if app_process_running; then
        sleep 2
        continue
    fi
    echo "[autostart] 启动 ${APP_NAME}: ${APP_LAUNCH}"
    ${APP_LAUNCH}
    echo "[autostart] ${APP_NAME} 已退出，2 秒后重启"
    sleep 2
done
